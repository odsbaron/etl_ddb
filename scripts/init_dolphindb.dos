// 创建日期值分区数据库（2020.01.01 ~ 2027.12.31，每天一个分区）
db = database("dfs://user_dsou_jydb_202604", VALUE, date(1990.01.01)..date(2030.12.31))

// 定义表结构
schema = table(
    1:0,
    `orderId`customer`amt`updateTime,
    [SYMBOL, STRING, DOUBLE, TIMESTAMP]
)

// 创建分布式表，按 updateTime 日期分区
db.createPartitionedTable(schema, `orders, `updateTime)
